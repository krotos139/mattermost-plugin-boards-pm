{
    "id": "focalboard",
    "name": "Mattermost Boards (PM fork)",
    "description": "Mattermost Boards plugin with project-management extensions: Timeline view, deadlines + DM reminders, dashboard boards, mobile login handoff.",
    "homepage_url": "https://github.com/krotos139/mattermost-plugin-boards-pm",
    "support_url": "https://github.com/krotos139/mattermost-plugin-boards-pm/issues",
    "release_notes_url": "https://github.com/krotos139/mattermost-plugin-boards-pm/releases/tag/v1.1.5",
    "icon_path": "assets/starter-template-icon.svg",
    "version": "1.1.5",
    "min_server_version": "10.7.0",
    "server": {
        "executables": {
            "linux-amd64": "server/dist/plugin-linux-amd64",
            "linux-arm64": "server/dist/plugin-linux-arm64",
            "darwin-amd64": "server/dist/plugin-darwin-amd64",
            "darwin-arm64": "server/dist/plugin-darwin-arm64",
            "windows-amd64": "server/dist/plugin-windows-amd64.exe"
        }
    },
    "webapp": {
        "bundle_path": "webapp/dist/main.js"
    },
    "settings_schema": {
        "header": "",
        "footer": "",
        "settings": [{
            "key": "EnablePublicSharedBoards",
            "type": "bool",
            "display_name": "Enable Publicly-Shared Boards:",
            "default": false,
            "help_text": "This allows board editors to share boards that can be accessed by anyone with the link."
        }, {
            "key": "EnableMCPServer",
            "type": "bool",
            "display_name": "Enable MCP Server:",
            "default": false,
            "help_text": "Run a Model Context Protocol server so AI agents can drive Boards. Users mint personal API keys with `/boards getapi`."
        }, {
            "key": "MCPListenAddress",
            "type": "text",
            "display_name": "MCP Listen Address:",
            "default": "127.0.0.1:8975",
            "help_text": "host:port for the MCP listener. Default `127.0.0.1:8975` (loopback only). Use `0.0.0.0:<port>` to accept connections from outside the host — every TCP request must then carry an API key."
        }, {
            "key": "MCPRequireBearerOnLoopback",
            "type": "bool",
            "display_name": "Require API key on loopback:",
            "default": false,
            "help_text": "Hardened mode: even local 127.0.0.1 callers must present a Bearer key. Off by default."
        }, {
            "key": "MCPKeysTable",
            "type": "custom",
            "display_name": "Issued MCP API keys:",
            "default": null,
            "help_text": ""
        }]
    }
}
